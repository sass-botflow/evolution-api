# BotFlow Evolution API — production environment (all values, no placeholders)
# EasyPanel Compose: paste docker-compose.yml only — Environment tab must stay EMPTY.
# Backend EasyPanel: add EVOLUTION_* block below to the backend service.

# ═══════════════════════════════════════════════════════════════════════════════
# EVOLUTION COMPOSE (hardcoded in docker-compose.yml — reference copy)
# ═══════════════════════════════════════════════════════════════════════════════

SERVER_URL=https://evolution.api.botflow.ink
SERVER_PORT=8080
SERVER_DISABLE_DOCS=true
SERVER_DISABLE_MANAGER=true

AUTHENTICATION_API_KEY=e323292ec09f14a66514089b993e246eb469f3a04448ddc02167447e76621f18
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://botflow:botflow@sass-botflow_postgres:5432/evolution?schema=evolution_api&connection_limit=25&pool_timeout=30
DATABASE_CONNECTION_CLIENT_NAME=botflow_evolution

REDIS_URI=redis://evolution-redis:6379/1
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/1
CACHE_REDIS_PREFIX_KEY=botflow_evolution
CACHE_REDIS_TTL=604800
CACHE_REDIS_SAVE_INSTANCES=true

WEBSOCKET_ENABLED=true
WEBSOCKET_GLOBAL_EVENTS=true
WEBSOCKET_ALLOWED_HOSTS=api.botflow.ink,sass-botflow_backend,backend

WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=https://api.botflow.ink/webhooks/evolution
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# Events (MESSAGE_RECEIVED = MESSAGES_UPSERT in Evolution API v2)
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_SEND_MESSAGE=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_PRESENCE_UPDATE=true

# ═══════════════════════════════════════════════════════════════════════════════
# BOTFLOW BACKEND (EasyPanel → backend service Environment)
# ═══════════════════════════════════════════════════════════════════════════════

EVOLUTION_API_URL=http://sass-botflow_evolution-api:8080
EVOLUTION_API_KEY=e323292ec09f14a66514089b993e246eb469f3a04448ddc02167447e76621f18
EVOLUTION_WEBHOOK_SECRET=e323292ec09f14a66514089b993e246eb469f3a04448ddc02167447e76621f18

DATABASE_URL=postgresql://botflow:botflow@sass-botflow_postgres:5432/postgres?sslmode=disable
REDIS_URL=redis://sass-botflow_redis:6379

JWT_SECRET=botflow-production-jwt-secret-minimum-32-characters-long
CORS_ORIGIN=https://botflow.ink,https://www.botflow.ink
FRONTEND_URL=https://www.botflow.ink

# ═══════════════════════════════════════════════════════════════════════════════
# BOTFLOW FRONTEND (EasyPanel → frontend service Environment)
# ═══════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_API_URL=https://api.botflow.ink
BACKEND_API_URL=https://api.botflow.ink
NEXT_PUBLIC_APP_URL=https://www.botflow.ink
